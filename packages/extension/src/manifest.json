{
  "manifest_version": 3,
  "name": "RapidCheck.ro",
  "version": "0.1.0",
  "description": "Verifică rapid site-uri, formulare și plăți online. Anti-phishing, date sensibile, privacy-first.",
  "minimum_chrome_version": "120",
  "permissions": ["storage", "scripting", "activeTab", "webNavigation"],
  "host_permissions": [
    "https://raw.githubusercontent.com/*",
    "*://*.anaf.ro/*",
    "*://dgep.mai.gov.ro/*",
    "*://*.depabd.mai.gov.ro/*",
    "*://portal.just.ro/*",
    "*://*.ghiseul.ro/*",
    "*://*.rotld.ro/*",
    "*://itmcluj.ro/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://*.google.com/search*",
        "*://www.google.com/search*",
        "*://google.com/search*",
        "*://*.google.ro/search*",
        "*://www.google.ro/search*",
        "*://google.ro/search*",
        "*://*.google.md/search*",
        "*://bing.com/search*",
        "*://www.bing.com/search*",
        "*://duckduckgo.com/*",
        "*://yandex.ru/search*",
        "*://yandex.com/search*",
        "*://ecosia.org/search*",
        "*://www.ecosia.org/search*"
      ],
      "js": ["serp.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "proof.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "RapidCheck.ro",
    "default_icon": {
      "16": "icons/rapidcheck-16.png",
      "32": "icons/rapidcheck-32.png",
      "48": "icons/rapidcheck-48.png"
    }
  },
  "icons": {
    "16": "icons/rapidcheck-16.png",
    "48": "icons/rapidcheck-48.png",
    "128": "icons/rapidcheck-128.png"
  }
}
